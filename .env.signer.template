# Nostr Signer Configuration
# This file is used ONLY by the nostr-signer container.
# The main agent container (base) does not have access to this secret.

# NOSTR_AGENT_SECRET can be either:
#   1) A nsec private key (e.g. nsec1...)
#   2) A path to a file that contains the nsec key (e.g. /run/secrets/nostr_agent_secret)
# The file content must be just the raw nsec key - one line, no quotes, no prefix.
# Here an example to create a new one:
# python3 -c "import nostr_sdk; k = nostr_sdk.Keys.generate(); print('Public Key (npub):', k.public_key().to_bech32()); print('Private Key (nsec):', k.secret_key().to_bech32()); print('Private Key (Hex): ', k.secret_key().to_hex())"
NOSTR_AGENT_SECRET="your_secret_hex_or_nsec_here"

# Signer service settings
SIGNER_PORT=8080
SIGNER_HOST=0.0.0.0
