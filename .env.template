# ROS 2 Network Configuration
ROS_DOMAIN_ID=55

# -- BACKEND SERVICE URLs --
#UPSTREAM_API_URL="https://api.deepseek.com/v1/"
UPSTREAM_API_URL="https://192.168.1.9:8022/v1/"
UPSTREAM_API_KEY=""
SEARXNG_URL="http://192.168.1.10:9080"
CRAWL4AI_URL="http://192.168.1.10:3020"
CRAWL4AI_API_KEY="local_instance"

# Search Service (SearXNG via Gateway)
MASTER_SEARXNG_URL="http://api-gateway:8080/search"
MASTER_SEARXNG_LANGUAGE="en-US"

# Crawl Service (Crawl4AI via Gateway)
MASTER_CRAWL4AI_URL="http://api-gateway:8080/crawl"

# LLM Node Configuration (expected by bob_llm package)
LLM_API_URL="http://api-gateway:8080/v1"
LLM_API_KEY="injected_by_gateway_proxy"
LLM_API_MODEL="deepseek-v4-flash"

ROS_NAMESPACE="/nostr"
LLM_NAME_SPACE="${ROS_NAMESPACE}"

# Nostr Memory Relays (comma-separated WebSocket URLs)
# For containerized environment (docker compose-base):
NOSTR_RELAYS="ws://nostr-relay-1:8080,ws://nostr-relay-2:8080"

# ------------------------------------------------------------------
# Chronology Skill (Redis-backed event log)
# ------------------------------------------------------------------
CHRONO_REDIS_HOST="nostr-redis"
CHRONO_REDIS_PORT="6379"
CHRONO_REDIS_DB="0"
CHRONO_STREAM_KEY="chronology:events"
CHRONO_MAX_EVENTS="10000"
CHRONO_TTL_HOURS="0"
CHRONO_TRIM_ON_LOG="true"

# ------------------------------------------------------------------
# Agent Contacts Skill (Redis-backed contact list + Nostr publishing)
# ------------------------------------------------------------------
# Reuses Chronology Redis by default; override individually if needed
# AGENT_CONTACTS_REDIS_HOST="nostr-redis"
# AGENT_CONTACTS_REDIS_PORT="6379"
# AGENT_CONTACTS_REDIS_DB="0"
# AGENT_CONTACTS_SET_KEY="chronology:agents:set"
# AGENT_CONTACTS_HASH_PREFIX="chronology:agents:"

# Default profile for Kind 0 (Metadata) events
AGENT_PROFILE_NAME="bob_nostr_agent"
AGENT_PROFILE_ABOUT="ROS 2 Nostr Agent - autonomous task scheduler"
AGENT_PROFILE_PICTURE=""